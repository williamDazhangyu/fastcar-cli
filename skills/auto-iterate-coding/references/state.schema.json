{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastcar.local/auto-iterate/state.schema.json",
  "title": "FastCar Auto Iterate State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "task",
    "session",
    "mode",
    "budgets",
    "currentState",
    "watchdog",
    "phaseGate",
    "implementationContract",
    "baseline",
    "iterationPolicy",
    "taskProfile",
    "decisionRequest",
    "requirements",
    "decisions",
    "traceability",
    "documentation",
    "deliveryDocs",
    "notes",
    "diagnose",
    "validation",
    "postChange",
    "deltaAssessment",
    "diffBudget",
    "cleanup",
    "styleConsolidation",
    "contextResetReview",
    "deliveryEvidence",
    "skillCapture",
    "postAgentValidationGate"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "language": {
      "type": "object",
      "required": ["code", "source", "confidence"],
      "properties": {
        "code": { "enum": ["zh", "en"] },
        "source": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    },
    "task": {
      "type": "object",
      "required": ["goal", "successCriteria", "nonGoals", "allowedScope", "compatibility"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "successCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "nonGoals": { "type": "array", "items": { "type": "string" } },
        "allowedScope": { "type": "string", "minLength": 1 },
        "compatibility": { "type": "array", "items": { "type": "string" } }
      }
    },
    "session": {
      "type": "object",
      "required": ["session", "stateJsonFile", "stateFile", "promptFile", "currentFile"],
      "properties": {
        "session": { "type": "string", "minLength": 1 },
        "stateJsonFile": { "type": "string", "minLength": 1 },
        "stateFile": { "type": "string", "minLength": 1 },
        "promptFile": { "type": "string", "minLength": 1 },
        "currentFile": { "type": "string", "minLength": 1 }
      }
    },
    "taskProfile": {
      "type": "object",
      "required": ["type", "complexity", "risk", "needsUserConfirmation", "reasons"],
      "properties": {
        "type": {
          "enum": ["feature", "bugfix", "docs", "refactor", "verify", "optimize", "prototype", "unknown"]
        },
        "complexity": { "enum": ["small", "medium", "large"] },
        "risk": { "enum": ["low", "medium", "high"] },
        "needsUserConfirmation": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decisionRequest": {
      "type": "object",
      "required": ["status", "topic", "background", "options", "recommended", "impact", "triggers"],
      "properties": {
        "status": { "enum": ["not_needed", "pending", "approved", "rejected", "blocked"] },
        "topic": { "type": "string", "minLength": 1 },
        "background": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "items": { "type": "string" } },
        "recommended": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "triggers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mode": {
      "type": "object",
      "required": ["mode", "label", "description", "autopilot", "runtimeAutopilot", "loopShape", "allowAgentInference", "allowModify", "instructions"],
      "properties": {
        "mode": { "enum": ["strict", "quick", "diagnose", "verify", "plan", "optimize", "prototype"] },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "autopilot": { "type": "boolean" },
        "runtimeAutopilot": { "type": "boolean" },
        "loopShape": { "enum": ["default", "autopilot", "plan_once"] },
        "allowAgentInference": { "type": "boolean" },
        "allowModify": { "type": "boolean" },
        "instructions": { "type": "string", "minLength": 1 }
      }
    },
    "budgets": {
      "type": "object",
      "required": [
        "maxIterations",
        "autopilotMaxIterations",
        "implementationIterationsUsed",
        "nonImplementationIterationsUsed",
        "validationHardeningIterationsUsed",
        "minimumValidationHardeningIterations",
        "optimizationIterationsUsed",
        "totalCycles",
        "remainingImplementationIterations",
        "remainingValidationHardeningIterations",
        "remainingOptimizationIterations"
      ],
      "properties": {
        "maxIterations": { "type": "integer", "minimum": 0 },
        "autopilotMaxIterations": { "type": "integer", "minimum": 0 },
        "minimumImplementationIterations": { "type": ["integer", "null"], "minimum": 1 },
        "implementationIterationsUsed": { "type": "integer", "minimum": 0 },
        "nonImplementationIterationsUsed": { "type": "integer", "minimum": 0 },
        "validationHardeningIterationsUsed": { "type": "integer", "minimum": 0 },
        "minimumValidationHardeningIterations": { "type": "integer", "minimum": 0 },
        "optimizationIterationsUsed": { "type": "integer", "minimum": 0 },
        "totalCycles": { "type": "integer", "minimum": 0 },
        "remainingImplementationIterations": { "type": "integer", "minimum": 0 },
        "remainingValidationHardeningIterations": { "type": "integer", "minimum": 0 },
        "remainingOptimizationIterations": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "currentState": {
      "type": "object",
      "required": [
        "currentPhase",
        "currentTask",
        "nextAction",
        "overallStatus",
        "recentChanges",
        "keyFiles",
        "lastValidationCommand",
        "lastValidationResult"
      ],
      "properties": {
        "currentPhase": { "type": "string", "minLength": 1 },
        "currentTask": { "type": "string", "minLength": 1 },
        "nextAction": { "type": "string", "minLength": 1 },
        "overallStatus": { "type": "string", "minLength": 1 },
        "recentChanges": { "type": "string", "minLength": 1 },
        "keyFiles": { "type": "string", "minLength": 1 },
        "lastValidationCommand": { "type": "string", "minLength": 1 },
        "lastValidationResult": { "type": "string", "minLength": 1 }
      }
    },
    "watchdog": {
      "type": "object",
      "required": [
        "enabled",
        "stateDrift",
        "deliveryVerifiability",
        "triggered",
        "requiredAction",
        "freshEyesRequired"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "stateDrift": { "type": "string", "minLength": 1 },
        "deliveryVerifiability": {
          "enum": ["verifiable", "partially_verifiable", "not_verifiable", "unknown"]
        },
        "triggered": { "type": "boolean" },
        "requiredAction": {
          "enum": ["continue", "narrow_scope", "run_validation", "reconcile", "ask_user", "stop", "context_compress_and_review"]
        },
        "freshEyesRequired": { "type": "boolean" },
        "validationHardeningStatus": { "type": "string" },
        "validationHardeningDimensionsDone": { "type": "array", "items": { "type": "string" } },
        "newTestCount": { "type": "integer", "minimum": 0 }
      }
    },
    "phaseGate": {
      "type": "object",
      "required": ["currentPhase", "canProceed", "blockingReasons", "gates"],
      "properties": {
        "currentPhase": {
          "enum": ["requirement", "contract", "baseline", "coding", "validation", "cleanup", "delivery"]
        },
        "canProceed": { "type": "boolean" },
        "blockingReasons": { "type": "array", "items": { "type": "string" } },
        "gates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase", "entryCriteria", "exitCriteria", "blockingRules", "status"],
            "properties": {
              "phase": {
                "enum": ["requirement", "contract", "baseline", "coding", "validation", "cleanup", "delivery"]
              },
              "entryCriteria": { "type": "array", "items": { "type": "string" } },
              "exitCriteria": { "type": "array", "items": { "type": "string" } },
              "blockingRules": { "type": "array", "items": { "type": "string" } },
              "status": { "enum": ["pending", "passed", "blocked", "skipped_with_reason"] }
            }
          }
        }
      }
    },
    "implementationContract": {
      "type": "object",
      "required": [
        "status",
        "goal",
        "understanding",
        "scope",
        "nonGoals",
        "successCriteria",
        "validationPlan",
        "riskPoints",
        "openQuestions",
        "userConfirmationRequired"
      ],
      "properties": {
        "status": { "enum": ["pending", "approved", "blocked"] },
        "goal": { "type": "string", "minLength": 1 },
        "understanding": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "nonGoals": { "type": "string", "minLength": 1 },
        "successCriteria": { "type": "string", "minLength": 1 },
        "validationPlan": { "type": "string", "minLength": 1 },
        "riskPoints": { "type": "string", "minLength": 1 },
        "openQuestions": { "type": "array", "items": { "type": "string" } },
        "userConfirmationRequired": { "type": "boolean" }
      }
    },
    "baseline": {
      "type": "object",
      "required": ["status", "command", "result", "reason", "failureCategory", "allowsCoding"],
      "properties": {
        "status": { "enum": ["pending", "passed", "failed", "skipped_with_reason", "not_available"] },
        "command": { "type": "string", "minLength": 1 },
        "result": { "type": ["string", "null"], "minLength": 1 },
        "reason": { "type": ["string", "null"], "minLength": 1 },
        "failureCategory": {
          "enum": ["none", "existing_failure", "new_failure", "environment_failure", "test_unavailable", "unknown"]
        },
        "allowsCoding": { "type": "boolean" }
      }
    },
    "iterationPolicy": {
      "type": "object",
      "required": [
        "currentIterationGoal",
        "maxGoalsPerIteration",
        "maxChangedFiles",
        "maxDiffLines",
        "maxNoProgressIterations",
        "consecutiveFailureCount",
        "allowedFiles",
        "stopConditions",
        "rollbackPlan",
        "lastDecision"
      ],
      "properties": {
        "currentIterationGoal": { "type": "string", "minLength": 1 },
        "maxGoalsPerIteration": { "const": 1 },
        "maxChangedFiles": { "type": "integer", "minimum": 0 },
        "maxDiffLines": { "type": "integer", "minimum": 0 },
        "maxNoProgressIterations": { "type": "integer", "minimum": 0 },
        "consecutiveFailureCount": { "type": "integer", "minimum": 0 },
        "allowedFiles": { "type": "array", "items": { "type": "string" } },
        "stopConditions": { "type": "array", "items": { "type": "string" } },
        "rollbackPlan": { "type": "array", "items": { "type": "string" } },
        "lastDecision": { "enum": ["continue", "stop", "ask_user", "replan", "revert"] }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "traceability": {
      "type": "object",
      "required": ["policy", "iterations"],
      "properties": {
        "policy": { "type": "string", "minLength": 1 },
        "iterations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "iteration": { "type": "integer", "minimum": 1 },
              "status": { "type": "string" },
              "summary": { "type": "string" },
              "rationaleSummary": { "type": "string" },
              "decisions": { "type": "array" },
              "evidence": { "type": "array" },
              "filesChanged": { "type": "array", "items": { "type": "string" } },
              "promptPath": { "type": "string" },
              "resultPath": { "type": "string" },
              "logPath": { "type": "string" }
            }
          }
        }
      }
    },
    "documentation": {
      "type": "object",
      "required": ["apiChanges", "architectureNotes", "implementationNotes", "changelogEntries"],
      "properties": {
        "apiChanges": { "type": "array" },
        "architectureNotes": { "type": "array" },
        "implementationNotes": { "type": "array" },
        "changelogEntries": { "type": "array" }
      }
    },
    "deliveryDocs": {
      "type": "object",
      "required": ["status", "path", "files"],
      "properties": {
        "status": { "enum": ["pending", "generated", "blocked", "not_available"] },
        "path": { "type": "string", "minLength": 1 },
        "files": { "type": "array", "items": { "type": "string" } },
        "generatedAt": { "type": ["string", "null"] }
      }
    },
    "subAgentDispatch": {
      "type": "object",
      "required": [
        "enabled",
        "currentPhase",
        "activeSubAgents",
        "subAgentHistory",
        "dispatchedCount",
        "completedCount",
        "failedCount",
        "lastDispatchRound",
        "lastMergeResult"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "currentPhase": { "type": "string", "minLength": 1 },
        "activeSubAgents": {
          "type": "array",
          "items": { "$ref": "#/$defs/subAgent" }
        },
        "subAgentHistory": {
          "type": "array",
          "items": { "$ref": "#/$defs/subAgent" }
        },
        "dispatchedCount": { "type": "integer", "minimum": 0 },
        "completedCount": { "type": "integer", "minimum": 0 },
        "failedCount": { "type": "integer", "minimum": 0 },
        "lastDispatchRound": { "type": "integer", "minimum": 0 },
        "lastMergeResult": { "type": "string" },
        "maxSubAgentRounds": { "type": "integer", "minimum": 0 },
        "subAgentTimeoutSeconds": { "type": "integer", "minimum": 0 },
        "maxFailedSubAgents": { "type": "integer", "minimum": 0 },
        "concurrencyLimit": { "type": "integer", "minimum": 0 }
      }
    },
    "diagnose": {
      "type": "object",
      "required": ["hypotheses"],
      "properties": {
        "hypotheses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hypothesisQueue": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "summary", "priority", "status"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 },
              "priority": { "type": "number" },
              "status": { "enum": ["pending", "supported", "rejected", "inconclusive"] },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "summary", "type", "status", "relatedFiles", "evidence", "blockedReason", "nextStep"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pending", "implemented", "passed", "blocked", "not_verified"] },
          "relatedFiles": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "string", "minLength": 1 },
          "blockedReason": { "type": "string", "minLength": 1 },
          "nextStep": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decisions": {
      "type": "object",
      "required": [
        "compatibility",
        "constraints",
        "parallelWriteAllowed",
        "parallelWriteConfirmation",
        "coderFileOwnership",
        "fallbackStrategy"
      ],
      "properties": {
        "compatibility": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "parallelWriteAllowed": { "type": "boolean" },
        "parallelWriteConfirmation": { "type": "string", "minLength": 1 },
        "coderFileOwnership": { "type": "string", "minLength": 1 },
        "fallbackStrategy": { "type": "string", "minLength": 1 }
      }
    },
    "validation": {
      "type": "object",
      "required": ["passed", "failed", "notRunReason", "finalVerifiability", "commands"],
      "properties": {
        "passed": { "type": "array" },
        "failed": { "type": "array" },
        "notRunReason": { "type": "string", "minLength": 1 },
        "finalVerifiability": {
          "enum": ["verifiable", "partially_verifiable", "not_verifiable", "unknown"]
        },
        "commands": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "additionalProperties": true,
                "required": ["command"],
                "properties": {
                  "command": { "type": "string", "minLength": 1 },
                  "result": {
                    "enum": ["passed", "failed", "skipped", "not_run", "not_available", "skipped_with_reason"]
                  },
                  "status": {
                    "enum": ["passed", "failed", "skipped", "not_run", "not_available", "skipped_with_reason"]
                  },
                  "summary": { "type": "string" },
                  "exitCode": { "type": ["integer", "null"] },
                  "iteration": { "type": "integer", "minimum": 1 }
                }
              }
            ]
          }
        }
      }
    },
    "optimization": {
      "type": "object",
      "properties": {
        "status": { "enum": ["pending", "implemented", "optimized", "passed", "not_verified", "no_improvement", "completed"] },
        "baselineMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "postMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "pendingMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "metricComparison": {
          "type": "object",
          "properties": {
            "status": { "enum": ["improved", "unchanged", "regression", "unknown"] },
            "comparisons": { "type": "array" }
          }
        },
        "noImprovementStreak": { "type": "integer", "minimum": 0 },
        "maxNoImprovementIterations": { "type": "integer", "minimum": 1 },
        "stopReason": { "type": "string" }
      }
    },
    "postChange": {
      "type": "object",
      "required": ["status", "command", "result", "reason", "regressionDetected"],
      "properties": {
        "status": { "enum": ["not_run", "passed", "failed", "skipped_with_reason", "not_available"] },
        "command": { "type": "string", "minLength": 1 },
        "result": { "type": ["string", "null"], "minLength": 1 },
        "reason": { "type": ["string", "null"], "minLength": 1 },
        "regressionDetected": { "type": "boolean" },
        "perCommand": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["command", "status"],
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "status": {
                "enum": ["not_run", "passed", "failed", "skipped", "skipped_with_reason", "not_available"]
              },
              "result": { "type": ["string", "null"] },
              "exitCode": { "type": ["integer", "null"] },
              "signal": { "type": "string" },
              "error": { "type": "string" },
              "durationMs": { "type": "integer", "minimum": 0 },
              "stdoutTail": { "type": "string" },
              "stderrTail": { "type": "string" }
            }
          }
        }
      }
    },
    "deltaAssessment": {
      "type": "object",
      "required": ["status", "summary", "baselineRef", "postChangeRef", "decision"],
      "properties": {
        "status": { "enum": ["pending", "improved", "unchanged", "regression", "unknown"] },
        "summary": { "type": "string", "minLength": 1 },
        "baselineRef": { "type": "string", "minLength": 1 },
        "postChangeRef": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["keep", "revert", "retry_new_direction", "stop", "ask_user"] }
      }
    },
    "diffBudget": {
      "type": "object",
      "required": ["status", "changedFiles", "diffLines", "outOfScopeFiles", "highRiskFiles", "reason"],
      "properties": {
        "status": { "enum": ["not_checked", "within_budget", "over_budget", "unknown"] },
        "changedFiles": { "type": "integer", "minimum": 0 },
        "diffLines": { "type": "integer", "minimum": 0 },
        "outOfScopeFiles": { "type": "array", "items": { "type": "string" } },
        "highRiskFiles": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "cleanup": {
      "type": "object",
      "required": ["status", "artifactsToDelete", "prototypeFiles"],
      "properties": {
        "status": { "enum": ["pending", "completed", "blocked"] },
        "artifactsToDelete": { "type": "string", "minLength": 1 },
        "prototypeFiles": { "type": "string", "minLength": 1 }
      }
    },
    "styleConsolidation": {
      "type": "object",
      "required": ["status", "trigger", "localSkillsReviewed", "globalSkillsReviewed", "appliedRules", "changedFiles", "scope", "summary", "verificationSummary", "skippedReasons", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "completed", "not_applicable", "blocked", "not_available"]
        },
        "trigger": { "type": "string", "minLength": 1 },
        "localSkillsReviewed": { "type": "array", "items": { "type": "string" } },
        "globalSkillsReviewed": { "type": "array", "items": { "type": "string" } },
        "appliedRules": { "type": "array", "items": { "type": "string" } },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "verificationSummary": { "type": "string", "minLength": 1 },
        "skippedReasons": { "type": "array", "items": { "type": "string" } },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    },
    "contextResetReview": {
      "type": "object",
      "required": ["status", "trigger", "reviewCyclesUsed", "maxReviewCycles", "sourceOfTruth", "standardsFindings", "specFindings", "decision", "reopenedRequirements", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "passed", "failed", "blocked", "not_available", "user_accepted_limited"]
        },
        "trigger": { "type": "string", "minLength": 1 },
        "reviewCyclesUsed": { "type": "integer", "minimum": 0 },
        "maxReviewCycles": { "type": "integer", "minimum": 0 },
        "sourceOfTruth": { "type": "string", "minLength": 1 },
        "standardsFindings": { "type": "array", "items": { "type": "string" } },
        "specFindings": { "type": "array", "items": { "type": "string" } },
        "decision": {
          "enum": ["not_run", "pass", "reopen_requirements", "block", "limited_acceptance"]
        },
        "reopenedRequirements": { "type": "array", "items": { "type": "string" } },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    },
    "deliveryEvidence": {
      "type": "object",
      "required": [
        "status",
        "goal",
        "changes",
        "changedFiles",
        "validationSummary",
        "baselineComparison",
        "cleanupSummary",
        "risks",
        "unfinishedItems",
        "userConfirmation"
      ],
      "properties": {
        "status": { "enum": ["pending", "ready", "blocked", "delivered"] },
        "goal": { "type": "string", "minLength": 1 },
        "changes": { "type": "string", "minLength": 1 },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "validationSummary": { "type": "string", "minLength": 1 },
        "baselineComparison": { "type": "string", "minLength": 1 },
        "cleanupSummary": { "type": "string", "minLength": 1 },
        "risks": { "type": "string", "minLength": 1 },
        "unfinishedItems": { "type": "string", "minLength": 1 },
        "userConfirmation": { "type": "string", "minLength": 1 }
      }
    },
    "postAgentValidationGate": {
      "type": "object",
      "required": ["enabled", "command", "lastResult", "repairCyclesUsed", "maxRepairCycles", "failureSummary", "nextAction"],
      "properties": {
        "enabled": { "type": "boolean" },
        "command": { "type": "string", "minLength": 1 },
        "lastResult": { "enum": ["passed", "failed", "not_run"] },
        "repairCyclesUsed": { "type": "integer", "minimum": 0 },
        "maxRepairCycles": { "type": "integer", "minimum": 0 },
        "failureSummary": { "type": "array", "items": { "type": "string" } },
        "nextAction": { "enum": ["deliver", "context_reset_and_repair", "stop"] }
      }
    },
    "skillCapture": {
      "type": "object",
      "required": ["status", "root", "indexFile", "capturedFiles", "pendingCandidates", "skippedReasons", "selectionCriteria", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "captured", "skipped_no_high_value", "blocked", "not_available"]
        },
        "root": { "const": ".agents/skills" },
        "indexFile": { "const": ".agents/skills/index.md" },
        "capturedFiles": { "type": "array", "items": { "type": "string" } },
        "pendingCandidates": { "type": "array", "items": { "type": "string" } },
        "skippedReasons": { "type": "array", "items": { "type": "string" } },
        "selectionCriteria": { "type": "string", "minLength": 1 },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["name", "value", "direction"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": {},
        "unit": { "type": "string" },
        "direction": { "enum": ["lower_is_better", "higher_is_better"] },
        "source": { "type": "string" }
      }
    },
    "subAgent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "agent_id": { "type": "string" },
        "type": { "type": "string" },
        "task": { "type": "string" },
        "taskSummary": { "type": "string" },
        "task_summary": { "type": "string" },
        "filesAssigned": { "type": "array", "items": { "type": "string" } },
        "filesChanged": {},
        "files_changed": {},
        "status": { "type": "string" },
        "failureReason": { "type": "string" },
        "failure_reason": { "type": "string" },
        "startedAt": { "type": ["string", "null"] },
        "completedAt": { "type": ["string", "null"] },
        "resultSummary": { "type": "string" },
        "mergeStatus": { "type": "string" },
        "mergeResult": { "type": "string" },
        "merge_result": { "type": "string" },
        "validationResult": { "type": "string" },
        "validation_result": { "type": "string" },
        "promptFile": { "type": "string" },
        "resultFile": { "type": "string" },
        "worktreeDir": { "type": ["string", "null"] },
        "round": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
