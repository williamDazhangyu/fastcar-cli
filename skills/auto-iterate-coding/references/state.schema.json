{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastcar.local/auto-iterate/state.schema.json",
  "title": "FastCar Auto Iterate State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "task",
    "session",
    "mode",
    "budgets",
    "currentState",
    "watchdog",
    "phaseGate",
    "implementationContract",
    "baseline",
    "iterationPolicy",
    "taskProfile",
    "decisionRequest",
    "requirements",
    "decisions",
    "traceability",
    "documentation",
    "deliveryDocs",
    "notes",
    "diagnose",
    "validation",
    "postChange",
    "deltaAssessment",
    "diffBudget",
    "cleanup",
    "styleConsolidation",
    "contextResetReview",
    "deliveryEvidence",
    "skillCapture",
    "postAgentValidationGate"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "language": {
      "type": "object",
      "required": ["code", "source", "confidence"],
      "properties": {
        "code": { "enum": ["zh", "en"] },
        "source": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    },
    "task": {
      "type": "object",
      "required": ["goal", "successCriteria", "nonGoals", "allowedScope", "compatibility"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "successCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "nonGoals": { "type": "array", "items": { "type": "string" } },
        "allowedScope": { "type": "string", "minLength": 1 },
        "compatibility": { "type": "array", "items": { "type": "string" } }
      }
    },
    "session": {
      "type": "object",
      "required": ["session", "stateJsonFile", "stateFile", "promptFile", "currentFile"],
      "properties": {
        "session": { "type": "string", "minLength": 1 },
        "stateJsonFile": { "type": "string", "minLength": 1 },
        "stateFile": { "type": "string", "minLength": 1 },
        "promptFile": { "type": "string", "minLength": 1 },
        "currentFile": { "type": "string", "minLength": 1 }
      }
    },
    "taskProfile": {
      "type": "object",
      "required": ["type", "complexity", "risk", "needsUserConfirmation", "reasons"],
      "properties": {
        "type": {
          "enum": ["feature", "bugfix", "docs", "refactor", "verify", "optimize", "prototype", "unknown"]
        },
        "complexity": { "enum": ["small", "medium", "large"] },
        "risk": { "enum": ["low", "medium", "high"] },
        "needsUserConfirmation": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decisionRequest": {
      "type": "object",
      "required": ["status", "topic", "background", "options", "recommended", "impact", "triggers"],
      "properties": {
        "status": { "enum": ["not_needed", "pending", "approved", "rejected", "blocked"] },
        "topic": { "type": "string", "minLength": 1 },
        "background": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "items": { "type": "string" } },
        "recommended": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "triggers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mode": {
      "type": "object",
      "required": ["mode", "label", "description", "autopilot", "runtimeAutopilot", "loopShape", "allowAgentInference", "allowModify", "instructions"],
      "properties": {
        "mode": { "enum": ["strict", "quick", "diagnose", "verify", "plan", "optimize", "prototype"] },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "autopilot": { "type": "boolean" },
        "runtimeAutopilot": { "type": "boolean" },
        "loopShape": { "enum": ["default", "autopilot", "plan_once"] },
        "allowAgentInference": { "type": "boolean" },
        "allowModify": { "type": "boolean" },
        "instructions": { "type": "string", "minLength": 1 }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "traceability": {
      "type": "object",
      "required": ["policy", "iterations"],
      "properties": {
        "policy": { "type": "string", "minLength": 1 },
        "iterations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "iteration": { "type": "integer", "minimum": 1 },
              "status": { "type": "string" },
              "summary": { "type": "string" },
              "rationaleSummary": { "type": "string" },
              "decisions": { "type": "array" },
              "evidence": { "type": "array" },
              "filesChanged": { "type": "array", "items": { "type": "string" } },
              "promptPath": { "type": "string" },
              "resultPath": { "type": "string" },
              "logPath": { "type": "string" }
            }
          }
        }
      }
    },
    "documentation": {
      "type": "object",
      "required": ["apiChanges", "architectureNotes", "implementationNotes", "changelogEntries"],
      "properties": {
        "apiChanges": { "type": "array" },
        "architectureNotes": { "type": "array" },
        "implementationNotes": { "type": "array" },
        "changelogEntries": { "type": "array" }
      }
    },
    "deliveryDocs": {
      "type": "object",
      "required": ["status", "path", "files"],
      "properties": {
        "status": { "enum": ["pending", "generated", "blocked", "not_available"] },
        "path": { "type": "string", "minLength": 1 },
        "files": { "type": "array", "items": { "type": "string" } },
        "generatedAt": { "type": ["string", "null"] }
      }
    },
    "diagnose": {
      "type": "object",
      "required": ["hypotheses"],
      "properties": {
        "hypotheses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hypothesisQueue": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "summary", "priority", "status"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 },
              "priority": { "type": "number" },
              "status": { "enum": ["pending", "supported", "rejected", "inconclusive"] },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "optimization": {
      "type": "object",
      "properties": {
        "status": { "enum": ["pending", "implemented", "optimized", "passed", "not_verified", "no_improvement", "completed"] },
        "baselineMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "postMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "pendingMetrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "metricComparison": {
          "type": "object",
          "properties": {
            "status": { "enum": ["improved", "unchanged", "regression", "unknown"] },
            "comparisons": { "type": "array" }
          }
        },
        "noImprovementStreak": { "type": "integer", "minimum": 0 },
        "maxNoImprovementIterations": { "type": "integer", "minimum": 1 },
        "stopReason": { "type": "string" }
      }
    },
    "postChange": {
      "type": "object",
      "required": ["status", "command", "result", "reason", "regressionDetected"],
      "properties": {
        "status": { "enum": ["not_run", "passed", "failed", "skipped_with_reason", "not_available"] },
        "command": { "type": "string", "minLength": 1 },
        "result": { "type": ["string", "null"], "minLength": 1 },
        "reason": { "type": ["string", "null"], "minLength": 1 },
        "regressionDetected": { "type": "boolean" },
        "perCommand": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "command": { "type": "string" },
              "status": { "type": "string" },
              "result": { "type": ["string", "null"] },
              "exitCode": { "type": ["integer", "null"] },
              "signal": { "type": "string" },
              "error": { "type": "string" },
              "durationMs": { "type": "integer" },
              "stdoutTail": { "type": "string" },
              "stderrTail": { "type": "string" }
            }
          }
        }
      }
    },
    "deltaAssessment": {
      "type": "object",
      "required": ["status", "summary", "baselineRef", "postChangeRef", "decision"],
      "properties": {
        "status": { "enum": ["pending", "improved", "unchanged", "regression", "unknown"] },
        "summary": { "type": "string", "minLength": 1 },
        "baselineRef": { "type": "string", "minLength": 1 },
        "postChangeRef": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["keep", "revert", "retry_new_direction", "stop", "ask_user"] }
      }
    },
    "diffBudget": {
      "type": "object",
      "required": ["status", "changedFiles", "diffLines", "outOfScopeFiles", "highRiskFiles", "reason"],
      "properties": {
        "status": { "enum": ["not_checked", "within_budget", "over_budget", "unknown"] },
        "changedFiles": { "type": "integer", "minimum": 0 },
        "diffLines": { "type": "integer", "minimum": 0 },
        "outOfScopeFiles": { "type": "array", "items": { "type": "string" } },
        "highRiskFiles": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "styleConsolidation": {
      "type": "object",
      "required": ["status", "trigger", "localSkillsReviewed", "globalSkillsReviewed", "appliedRules", "changedFiles", "scope", "summary", "verificationSummary", "skippedReasons", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "completed", "not_applicable", "blocked", "not_available"]
        },
        "trigger": { "type": "string", "minLength": 1 },
        "localSkillsReviewed": { "type": "array", "items": { "type": "string" } },
        "globalSkillsReviewed": { "type": "array", "items": { "type": "string" } },
        "appliedRules": { "type": "array", "items": { "type": "string" } },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "verificationSummary": { "type": "string", "minLength": 1 },
        "skippedReasons": { "type": "array", "items": { "type": "string" } },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    },
    "contextResetReview": {
      "type": "object",
      "required": ["status", "trigger", "reviewCyclesUsed", "maxReviewCycles", "sourceOfTruth", "standardsFindings", "specFindings", "decision", "reopenedRequirements", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "passed", "failed", "blocked", "not_available", "user_accepted_limited"]
        },
        "trigger": { "type": "string", "minLength": 1 },
        "reviewCyclesUsed": { "type": "integer", "minimum": 0 },
        "maxReviewCycles": { "type": "integer", "minimum": 0 },
        "sourceOfTruth": { "type": "string", "minLength": 1 },
        "standardsFindings": { "type": "array", "items": { "type": "string" } },
        "specFindings": { "type": "array", "items": { "type": "string" } },
        "decision": {
          "enum": ["not_run", "pass", "reopen_requirements", "block", "limited_acceptance"]
        },
        "reopenedRequirements": { "type": "array", "items": { "type": "string" } },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    },
    "postAgentValidationGate": {
      "type": "object",
      "required": ["enabled", "command", "lastResult", "repairCyclesUsed", "maxRepairCycles", "failureSummary", "nextAction"],
      "properties": {
        "enabled": { "type": "boolean" },
        "command": { "type": "string", "minLength": 1 },
        "lastResult": { "enum": ["passed", "failed", "not_run"] },
        "repairCyclesUsed": { "type": "integer", "minimum": 0 },
        "maxRepairCycles": { "type": "integer", "minimum": 0 },
        "failureSummary": { "type": "array", "items": { "type": "string" } },
        "nextAction": { "enum": ["deliver", "context_reset_and_repair", "stop"] }
      }
    },
    "skillCapture": {
      "type": "object",
      "required": ["status", "root", "indexFile", "capturedFiles", "pendingCandidates", "skippedReasons", "selectionCriteria", "lastRunSummary"],
      "properties": {
        "status": {
          "enum": ["pending", "captured", "skipped_no_high_value", "blocked", "not_available"]
        },
        "root": { "const": ".agents/skills" },
        "indexFile": { "const": ".agents/skills/index.md" },
        "capturedFiles": { "type": "array", "items": { "type": "string" } },
        "pendingCandidates": { "type": "array", "items": { "type": "string" } },
        "skippedReasons": { "type": "array", "items": { "type": "string" } },
        "selectionCriteria": { "type": "string", "minLength": 1 },
        "lastRunSummary": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["name", "value", "direction"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": {},
        "unit": { "type": "string" },
        "direction": { "enum": ["lower_is_better", "higher_is_better"] },
        "source": { "type": "string" }
      }
    }
  }
}
